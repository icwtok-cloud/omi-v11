# Base de datos (Render la inyecta automáticamente si usás su Postgres administrado)
DATABASE_URL=postgresql://user:password@localhost:5432/omi

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Frontend (para CORS). Acepta uno o más orígenes separados por coma --
# en producción poné tanto el apex como el "www" si el dominio redirige
# entre ellos (ej. https://omi.lat,https://www.omi.lat), porque el
# browser manda como Origin el dominio REAL post-redirect.
FRONTEND_URL=http://localhost:3000

# Pagos cripto
PAYMENT_RECEIVE_ADDRESS=0x0000000000000000000000000000000000000000
POLYGON_RPC_URL=https://polygon-rpc.com
BASE_RPC_URL=https://mainnet.base.org

# Lemon Squeezy (pagos con tarjeta)
# API key: Lemon Squeezy dashboard > Settings > API > "+"
LEMONSQUEEZY_API_KEY=
# Store ID: Settings > Stores (número al lado del nombre de la tienda)
LEMONSQUEEZY_STORE_ID=
# Signing secret: Settings > Webhooks > el webhook que apunte a
# https://tu-backend.onrender.com/webhooks/lemonsqueezy
LEMONSQUEEZY_WEBHOOK_SIGNING_SECRET=
# Variant IDs de cada producto (uno one-off, uno recurring mensual) --
# se ven en la URL del producto al editarlo en el dashboard
LEMONSQUEEZY_VARIANT_ID_PER_PROJECT=
LEMONSQUEEZY_VARIANT_ID_SUBSCRIPTION=

ENVIRONMENT=development
